[project]
name = "<%= pyPackageName %>"
version = "0.1.0"
description = "<%= spec.name %> CLI UI components — generated by asciibuddy."
requires-python = ">=3.9"
dependencies = [
  "rich>=13.0.0",
]

[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[tool.setuptools.packages.find]
where = ["src"]
