import chalk from "chalk";
import { theme } from "./theme.js";

export function defList(entries: Record<string, string | number | boolean | null | undefined>): void {
  const keys = Object.keys(entries);
  if (keys.length === 0) return;
  const width = Math.max(...keys.map((k) => k.length));
  const c = chalk.hex(theme.primaryColor);
  const lines: string[] = [];
  for (const k of keys) {
    const v = entries[k];
    const display = v === null || v === undefined ? chalk.dim("—") : String(v);
    lines.push(`${c(k.padEnd(width))}  ${display}`);
  }
  process.stdout.write(lines.join("\n") + "\n");
}
