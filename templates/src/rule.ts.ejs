import chalk from "chalk";
import { theme } from "./theme.js";

export interface RuleOptions {
  width?: number;
  align?: "left" | "center" | "right";
  char?: string;
}

export function rule(label?: string, opts: RuleOptions = {}): void {
  const width = opts.width ?? (process.stdout.columns ?? 80);
  const char = opts.char ?? theme.divider.fill;
  const c = chalk.hex(theme.primaryColor);
  if (!label) {
    process.stdout.write(chalk.dim(char.repeat(width)) + "\n");
    return;
  }
  const stamp = ` ${c(label)} `;
  const visibleLen = label.length + 2;
  const remaining = Math.max(0, width - visibleLen);
  const align = opts.align ?? "center";
  if (align === "left") {
    process.stdout.write(stamp + chalk.dim(char.repeat(remaining)) + "\n");
  } else if (align === "right") {
    process.stdout.write(chalk.dim(char.repeat(remaining)) + stamp + "\n");
  } else {
    const left = Math.floor(remaining / 2);
    const right = remaining - left;
    process.stdout.write(chalk.dim(char.repeat(left)) + stamp + chalk.dim(char.repeat(right)) + "\n");
  }
}
