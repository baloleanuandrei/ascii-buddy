import chalk from "chalk";
import { theme } from "./theme.js";

export interface GaugeOptions {
  width?: number;
  warnAt?: number;
  errorAt?: number;
  label?: string;
}

export function gauge(value: number, total: number, opts: GaugeOptions = {}): void {
  const ratio = total > 0 ? Math.max(0, Math.min(1, value / total)) : 0;
  const width = opts.width ?? 30;
  const fill = Math.round(ratio * width);
  const pct = Math.round(ratio * 100);
  let color: string = theme.primaryColor;
  if (opts.errorAt !== undefined && ratio >= opts.errorAt) color = "#ef4444";
  else if (opts.warnAt !== undefined && ratio >= opts.warnAt) color = "#f59e0b";
  const bar = chalk.hex(color)("█".repeat(fill)) + chalk.dim("░".repeat(width - fill));
  const label = opts.label ? chalk.dim(opts.label.padEnd(14)) + " " : "";
  process.stdout.write(`${label}${bar} ${chalk.bold(pct + "%")} ${chalk.dim(`(${value}/${total})`)}\n`);
}
