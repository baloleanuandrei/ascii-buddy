import chalk from "chalk";
import { theme } from "./theme.js";

const BLOCKS = ["▁", "▂", "▃", "▄", "▅", "▆", "▇", "█"];

export interface SparklineOptions {
  min?: number;
  max?: number;
  color?: string;
}

export function sparkline(values: number[], opts: SparklineOptions = {}): string {
  if (values.length === 0) return "";
  const min = opts.min ?? Math.min(...values);
  const max = opts.max ?? Math.max(...values);
  const range = max - min || 1;
  const color = opts.color ?? theme.primaryColor;
  return chalk.hex(color)(
    values
      .map((v) => {
        const idx = Math.min(BLOCKS.length - 1, Math.max(0, Math.floor(((v - min) / range) * (BLOCKS.length - 1))));
        return BLOCKS[idx];
      })
      .join("")
  );
}
