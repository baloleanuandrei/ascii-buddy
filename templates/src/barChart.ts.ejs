import chalk from "chalk";
import { theme } from "./theme.js";

export interface BarRow {
  label: string;
  value: number;
  color?: string;
}

export interface BarChartOptions {
  width?: number;
  max?: number;
  showValues?: boolean;
}

export function barChart(rows: BarRow[], opts: BarChartOptions = {}): void {
  if (rows.length === 0) return;
  const max = opts.max ?? Math.max(...rows.map((r) => r.value));
  const termWidth = process.stdout.columns ?? 80;
  const labelW = Math.max(...rows.map((r) => r.label.length));
  const showValues = opts.showValues ?? true;
  const valueW = showValues ? Math.max(...rows.map((r) => String(r.value).length)) + 2 : 0;
  const barW = Math.max(8, (opts.width ?? termWidth) - labelW - valueW - 4);
  const out: string[] = [];
  for (const row of rows) {
    const ratio = max > 0 ? row.value / max : 0;
    const fill = Math.round(ratio * barW);
    const color = row.color ?? theme.primaryColor;
    const bar = chalk.hex(color)("█".repeat(fill)) + chalk.dim("░".repeat(barW - fill));
    const value = showValues ? " " + chalk.dim(String(row.value)) : "";
    out.push(`${row.label.padEnd(labelW)}  ${bar}${value}`);
  }
  process.stdout.write(out.join("\n") + "\n");
}
