import chalk from "chalk";
import { readFileSync } from "node:fs";
import { theme } from "./theme.js";

const ERROR_COLOR = "#ef4444";

interface Frame {
  fn: string;
  file: string;
  line: number;
  col: number;
}

function parseFrames(stack: string): Frame[] {
  const frames: Frame[] = [];
  for (const line of stack.split("\n")) {
    const m =
      line.match(/at\s+(.+?)\s+\((.+):(\d+):(\d+)\)/) ||
      line.match(/at\s+(.+):(\d+):(\d+)/);
    if (!m) continue;
    if (m.length === 5) {
      frames.push({ fn: m[1], file: m[2], line: Number(m[3]), col: Number(m[4]) });
    } else {
      frames.push({ fn: "<anonymous>", file: m[1], line: Number(m[2]), col: Number(m[3]) });
    }
  }
  return frames;
}

function codeFrame(file: string, line: number, col: number): string {
  try {
    const src = readFileSync(file, "utf8").split("\n");
    const start = Math.max(0, line - 3);
    const end = Math.min(src.length, line + 2);
    const out: string[] = [];
    for (let i = start; i < end; i++) {
      const n = i + 1;
      const marker = n === line ? chalk.hex(ERROR_COLOR)("›") : " ";
      const num = String(n).padStart(4, " ");
      out.push(`${marker} ${chalk.dim(num)} | ${src[i] ?? ""}`);
      if (n === line) {
        out.push(`  ${" ".repeat(4)} | ${" ".repeat(Math.max(0, col - 1))}${chalk.hex(ERROR_COLOR)("^")}`);
      }
    }
    return out.join("\n");
  } catch {
    return "";
  }
}

export function formatError(err: unknown): string {
  const e = err instanceof Error ? err : new Error(String(err));
  const lines: string[] = [];
  lines.push(chalk.hex(ERROR_COLOR)(theme.symbols.error) + " " + chalk.bold(e.name) + ": " + e.message);
  const frames = parseFrames(e.stack ?? "");
  const top = frames.find((f) => !f.file.includes("node:") && !f.file.includes("node_modules"));
  if (top) {
    lines.push("");
    lines.push(chalk.dim(`  at ${top.fn} (${top.file}:${top.line}:${top.col})`));
    const frame = codeFrame(top.file, top.line, top.col);
    if (frame) {
      lines.push("");
      lines.push(frame);
    }
  }
  if (frames.length > 1) {
    lines.push("");
    lines.push(chalk.dim("  stack:"));
    for (const f of frames.slice(0, 6)) {
      lines.push(chalk.dim(`    ${f.fn} (${f.file}:${f.line}:${f.col})`));
    }
  }
  return lines.join("\n");
}

export function printError(err: unknown): void {
  process.stderr.write(formatError(err) + "\n");
}
