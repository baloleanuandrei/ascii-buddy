"import {
  banner,
  success,
  error,
  warning,
  info,
  section,
  table,
  spinner,
  progress,
  tasks,
  box,
  diff,
  formatError,
  heading,
  alert,
  badge,
  badges,
  defList,
  tree,
  steps,
  stats,
  code,
  timeline,
  emptyState,
  rule,
  columns,
  sparkline,
  barChart,
  gauge,
  json,
  markdown,
  link,
  gradient,
} from "./index.js";

async function main() {
  banner();

  section("Messages");
  success();
  success("Deployed to acme.com");
  error();
  error("Build failed: missing env var");
  warning();
  warning("Using deprecated API");
  info();
  info("Tip: run --help for usage");

  section("Table");
  table(
    ["Service", "Status", "Region"],
    [
      ["api", "ready", "iad1"],
      ["worker", "ready", "sfo1"],
      ["queue", "pending", "fra1"],
    ]
  );

  section("Spinner");
  const stop = spinner("Doing important work...");
  await new Promise((r) => setTimeout(r, 1200));
  stop();
  success("Work complete");

  section("Progress");
  const bar = progress(20, "Downloading");
  for (let i = 0; i < 20; i++) {
    await new Promise((r) => setTimeout(r, 40));
    bar.increment();
  }
  bar.stop();

  section("Tasks");
  await tasks([
    { title: "Resolve dependencies", run: () => new Promise((r) => setTimeout(r, 300)) },
    { title: "Compile sources",       run: () => new Promise((r) => setTimeout(r, 400)) },
    { title: "Bundle assets",         run: () => new Promise((r) => setTimeout(r, 300)) },
  ]);

  section("Box");
  process.stdout.write(box("Branded panel content.\\nMulti-line supported.", { title: "Acme" }) + "\\n");

  section("Diff");
  process.stdout.write(diff("hello\\nworld\\n", "hello\\nbrand\\n") + "\\n");

  section("Errors");
  try {
    throw new Error("Example failure for preview");
  } catch (e) {
    process.stdout.write(formatError(e) + "\\n");
  }

  heading("Heading levels", 1);
  heading("Subsection", 2);
  heading("Detail", 3);

  section("Alert");
  alert("Database migrations completed successfully.\\nAll 12 tables updated.", { kind: "success", title: "Deploy" });
  alert("Token expires in 2 days. Rotate before expiry.", { kind: "warning", title: "Heads up", actions: ["acme auth rotate", "docs: rotation"] });

  section("Badges");
  process.stdout.write(badges([
    { text: "v2.0.0", tone: "default" },
    { text: "stable", tone: "success" },
    { text: "beta", tone: "warning" },
    { text: "deprecated", tone: "error" },
    { text: "internal", tone: "neutral" },
  ]) + "\\n");

  section("Config");
  defList({
    "Environment": "production",
    "Region": "iad1",
    "Replicas": 3,
    "Auto-scale": true,
    "Secrets": null,
  });

  section("Tree");
  tree({
    label: "acme/",
    children: [
      { label: "src/", children: [
        { label: "index.ts" },
        { label: "config.ts" },
      ] },
      { label: "tests/", children: [{ label: "index.test.ts" }] },
      { label: "package.json" },
    ],
  });

  section("Steps");
  steps(["Init", "Build", "Test", "Deploy"], 2);

  section("Stats");
  stats([
    { label: "Requests", value: "12.4k", delta: "+3.2%", trend: "up" },
    { label: "P99", value: "84ms", delta: "-12ms", trend: "down" },
    { label: "Errors", value: "0.04%", trend: "flat" },
  ]);

  section("Code");
  code("const x: number = 42;\\nfunction greet(name: string) {\\n  return \`hello, \${name}\`;\\n}", { lang: "typescript", showLineNumbers: true });

  section("Timeline");
  timeline([
    { time: "10:01", title: "Build started", kind: "info" },
    { time: "10:04", title: "Tests passed", body: "248 tests, 0 failures", kind: "success" },
    { time: "10:05", title: "Deploy queued", kind: "info" },
    { time: "10:08", title: "Deploy complete", kind: "success" },
  ]);

  section("Empty state");
  emptyState("No deployments yet.", { hint: "Run a deploy to see history here.", command: "acme deploy" });

  rule("v2.0.0");

  section("Columns");
  columns(["api", "worker", "queue", "scheduler", "auth", "cache", "billing", "search", "ingest", "ml"]);

  section("Sparklines");
  process.stdout.write("requests  " + sparkline([3, 5, 8, 4, 9, 12, 6, 7, 11, 14, 9, 13, 16]) + "  +18%\\n");
  process.stdout.write("latency   " + sparkline([82, 90, 88, 95, 91, 84, 80, 78, 82, 79, 75, 72, 70]) + "  -14ms\\n");

  section("Bundle size");
  barChart([
    { label: "client.js", value: 248 },
    { label: "vendor.js", value: 612 },
    { label: "styles.css", value: 84 },
    { label: "fonts.woff", value: 156 },
  ]);

  section("Gauges");
  gauge(72, 100, { label: "disk", warnAt: 0.7, errorAt: 0.9 });
  gauge(94, 100, { label: "memory", warnAt: 0.7, errorAt: 0.9 });
  gauge(31, 100, { label: "cpu", warnAt: 0.7, errorAt: 0.9 });

  section("JSON");
  json({ name: "Acme", version: "2.0.0", features: ["banner", "messages", "spinner"], deployed: true, replicas: 3, env: null });

  section("Markdown");
  markdown("## What's new\\n\\n- Added 12 new components\\n- Improved theme system\\n\\nSee [docs](https://example.com) or run \`acme help\`.");

  section("Link");
  process.stdout.write("Dashboard: " + link("acme.dev/dashboard", "https://acme.dev/dashboard") + "\\n");

  section("Gradient");
  process.stdout.write(gradient("ACME — branded gradient", ["#7C3AED", "#22d3ee"]) + "\\n");

  process.stdout.write("\\n");
}

main();
"
`;

exports[`template rendering > pack: candy > renders src/progress.ts.ejs 1`] = `
"import cliProgress from "cli-progress";
import ora, { type Ora } from "ora";
import chalk from "chalk";
import { theme } from "./theme.js";

export interface ProgressBar {
  update(value: number): void;
  increment(delta?: number): void;
  stop(): void;
}

export function progress(total: number, label = ""): ProgressBar {
  const color = chalk.hex(theme.primaryColor);
  const bar = new cliProgress.SingleBar(
    {
      format: \`\${label ? color(label) + " " : ""}\${color("{bar}")} {percentage}% | {value}/{total}\`,
      barCompleteChar: "█",
      barIncompleteChar: "░",
      hideCursor: true,
    },
    cliProgress.Presets.shades_classic
  );
  bar.start(total, 0);
  return {
    update: (value) => bar.update(value),
    increment: (delta = 1) => bar.increment(delta),
    stop: () => bar.stop(),
  };
}

export interface Task {
  title: string;
  run: () => Promise<void> | void;
}

export async function tasks(items: Task[]): Promise<void> {
  for (const t of items) {
    const instance: Ora = ora({
      text: chalk.hex(theme.primaryColor)(t.title),
      spinner: { frames: [...theme.spinnerFrames], interval: theme.spinnerInterval },
    }).start();
    try {
      await t.run();
      instance.stopAndPersist({
        symbol: chalk.hex("#22c55e")(theme.symbols.success),
        text: t.title,
      });
    } catch (err) {
      instance.stopAndPersist({
        symbol: chalk.hex("#ef4444")(theme.symbols.error),
        text: \`\${t.title} — \${(err as Error).message}\`,
      });
      throw err;
    }
  }
}
"
`;

exports[`template rendering > pack: candy > renders src/prompts.ts.ejs 1`] = `
"import * as p from "@clack/prompts";
import chalk from "chalk";
import { theme } from "./theme.js";

function paint(s: string): string {
  return chalk.hex(theme.primaryColor)(s);
}

function check<T>(value: T | symbol): T {
  if (p.isCancel(value)) {
    p.cancel("Cancelled.");
    process.exit(0);
  }
  return value as T;
}

export async function text(message: string, opts: { placeholder?: string; initialValue?: string } = {}): Promise<string> {
  return check(await p.text({ message: paint(message), ...opts }));
}

export async function password(message: string): Promise<string> {
  return check(await p.password({ message: paint(message) }));
}

export async function confirm(message: string, initialValue = true): Promise<boolean> {
  return check(await p.confirm({ message: paint(message), initialValue }));
}

export interface Choice<T extends string = string> {
  value: T;
  label?: string;
  hint?: string;
}

function toClackOptions<T extends string>(options: Choice<T>[]): Array<{ value: T; label: string; hint?: string }> {
  return options.map((o) => {
    const opt: { value: T; label: string; hint?: string } = {
      value: o.value,
      label: o.label ?? o.value,
    };
    if (o.hint !== undefined) opt.hint = o.hint;
    return opt;
  });
}

export async function select<T extends string>(message: string, options: Choice<T>[]): Promise<T> {
  return check(
    // eslint-disable-next-line @typescript-eslint/no-explicit-any
    await p.select({ message: paint(message), options: toClackOptions(options) as any })
  ) as T;
}

export async function multiselect<T extends string>(
  message: string,
  options: Choice<T>[],
  opts: { required?: boolean; initialValues?: T[] } = {}
): Promise<T[]> {
  return check(
    await p.multiselect({
      message: paint(message),
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      options: toClackOptions(options) as any,
      required: opts.required ?? false,
      initialValues: opts.initialValues,
    })
  ) as T[];
}
"
`;

